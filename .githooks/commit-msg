#!/bin/sh
# Enforce Conventional Commits: https://www.conventionalcommits.org/
# Format: type(scope)!: subject
# Types: feat fix docs style refactor perf test build ci chore revert

msg_file="$1"
first_line=$(head -n1 "$msg_file")

# Allow merge/revert/fixup commits generated by git
case "$first_line" in
  Merge\ *|Revert\ *|fixup!\ *|squash!\ *) exit 0 ;;
esac

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9_\-\/]+\))?!?: .{1,100}$'

if ! printf '%s' "$first_line" | grep -Eq "$pattern"; then
  echo "ERROR: Commit message does not follow Conventional Commits." >&2
  echo "" >&2
  echo "  Format : type(scope): subject" >&2
  echo "  Types  : feat fix docs style refactor perf test build ci chore revert" >&2
  echo "" >&2
  echo "  Examples:" >&2
  echo "    feat(pair): add multi-monitor edge detection" >&2
  echo "    fix(input): stop cursor jitter at screen border" >&2
  echo "    docs: update pairing guide" >&2
  echo "" >&2
  echo "  Your message: $first_line" >&2
  exit 1
fi
